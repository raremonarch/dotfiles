# Mako configuration - Catppuccin Macchiato theme

# Appearance
font=AudioLink Mono 11
background-color=#24273a
text-color=#cad3f5
border-color=#8aadf4
border-size=2
border-radius=8
padding=12
margin=10

# Layout
width=350
height=150
max-visible=3
default-timeout=5000
ignore-timeout=0

# Icons
icons=1
max-icon-size=48
icon-path=/usr/share/icons/Adwaita

# Positioning
anchor=top-right
layer=overlay

# Urgency levels
[urgency=low]
border-color=#6e738d
background-color=#1e2030

[urgency=normal]
border-color=#8aadf4
background-color=#24273a

[urgency=critical]
border-color=#ed8796
background-color=#24273a
text-color=#ed8796
default-timeout=0
