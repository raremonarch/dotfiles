# Mako configuration - Neon Flow custom theme

# Appearance
font=AudioLink Mono 11
background-color=#161b22
text-color=#e6edf3
border-color=#58a6ff
border-size=1
border-radius=8
padding=12
margin=10

# Layout
width=350
height=150
max-visible=3
default-timeout=5000
ignore-timeout=0

# Icons
icons=1
max-icon-size=48
icon-path=/usr/share/icons/Adwaita

# Positioning
anchor=top-right
layer=overlay

# Urgency levels
[urgency=low]
border-color=#484f58
background-color=#0d1117

[urgency=normal]
border-color=#58a6ff
background-color=#161b22

[urgency=critical]
border-color=#ff7b72
background-color=#161b22
text-color=#ff7b72
default-timeout=0
